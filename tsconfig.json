{
  "compilerOptions": {
    "target": "es5",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
      "paths": {
        "@api/*": ["./src/api/*"],
        "@common/*": ["./src/common/*"],
        "@config/*": ["./src/config/*"],
        "@routes/*": ["./src/routes/*"],
        "@theme/*": ["./src/theme/*"],
        "@layout/*": ["./src/modules/layout/*"],
        "@products/*": ["./src/modules/products/*"],
        "@product-details/*": ["./src/modules/product-details/*"]
      }
  },
  "include": [
    "src"
  ]
}
